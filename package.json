{
  "name": "@sygnaal/icons",
  "version": "0.1.0",
  "description": "Typed React icon pack for the Sygnaal app.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build:icons": "node scripts/build-icons.mjs",
    "build": "npm run build:icons && tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist src/icons src/registry.ts"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "devDependencies": {
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "sharp": "^0.34.5",
    "svgo": "^3.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
